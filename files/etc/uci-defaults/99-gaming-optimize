#!/bin/sh
# ============================================================
# 99-gaming-optimize — OpenWrt FPS 游戏网络优化 (first-boot UCI defaults)
# ============================================================
# IPv4/IPv6 双栈 FPS 优化版本 (CS2/Steam 适配)
# - IPv4: NAT + fullcone + flow_offload + AliDNS DoH
# - IPv6: DHCPv6-PD (/56 前缀委派) + DHCPv6/SLAAC 混合 + 无 NAT
# - conntrack: sysctl UDP 超时 30s, max 131072 (见 sysctl.conf)
# ============================================================

. /lib/functions.sh

log() { echo "[gaming-optimize] $*"; }

log "Applying gaming network optimization (dual-stack)..."

# ─────────────────────────────────────────────
# 1. 防火墙优化
# ─────────────────────────────────────────────

uci set firewall.@defaults[0].flow_offloading='1'
uci set firewall.@defaults[0].flow_offloading_hw='0'
uci set firewall.@defaults[0].fullcone='1'
uci set firewall.@defaults[0].drop_invalid='1'
uci set firewall.@zone[0].mtu_fix='1'

# ICMPv6 Input (PMTU discovery — 游戏关键)
uci add firewall rule
uci set firewall.@rule[-1].name='ICMPv6-Input'
uci set firewall.@rule[-1].src='wan'
uci set firewall.@rule[-1].proto='icmp'
uci set firewall.@rule[-1].family='ipv6'
for t in echo-request echo-reply destination-unreachable packet-too-big \
         time-exceeded parameter-problem router-solicitation \
         neighbour-solicitation router-advertisement neighbour-advertisement; do
    uci add_list firewall.@rule[-1].icmp_type="$t"
done
uci set firewall.@rule[-1].limit='1000/sec'
uci set firewall.@rule[-1].target='ACCEPT'

# ICMPv6 Forward (客户端 PMTU 发现)
uci add firewall rule
uci set firewall.@rule[-1].name='ICMPv6-Forward'
uci set firewall.@rule[-1].src='wan'
uci set firewall.@rule[-1].dest='lan'
uci set firewall.@rule[-1].proto='icmp'
uci set firewall.@rule[-1].family='ipv6'
uci set firewall.@rule[-1].target='ACCEPT'

log "firewall: flow_offloading fullcone drop_invalid mtu_fix icmpv6"

# IPv6 TCP MSS clamping for PPPoE MTU 1492
# 防止 IPv6 大包超过 PPPoE 有效 MTU 导致丢包
cat >> /etc/firewall.user << 'FWEOF'
# IPv6 TCP MSS clamping (PPPoE MTU 1492)
ip6tables -t mangle -A FORWARD -p tcp --tcp-flags SYN,RST SYN -o pppoe-wan -j TCPMSS --clamp-mss-to-pmtu
FWEOF

log "firewall: ip6tables MSS clamp for PPPoE"

# ─────────────────────────────────────────────
# 2. IPv6 双栈: DHCPv6-PD over PPPoE
# ─────────────────────────────────────────────
# PPPoE 拨号时 IPv6CP 协商链路层地址
# wan_6: dhcpv6c 从 ISP 获取全球地址 + /56 前缀委派 (DHCPv6-PD)
# LAN: 从 /56 获取 /64 子网, DHCPv6 + SLAAC 混合模式
uci set network.wan.ipv6='1'
uci set network.lan.ipv6='1'
uci set network.lan.ip6assign='64'

# wan_6: DHCPv6 客户端 (挂载到 PPPoE wan)
uci delete network.wan_6 2>/dev/null
uci set network.wan_6='interface'
uci set network.wan_6.proto='dhcpv6'
uci set network.wan_6.device='@wan'
uci set network.wan_6.reqaddress='try'
uci set network.wan_6.reqprefix='56'
uci set network.wan_6.norelease='1'

uci delete network.globals.ula_prefix 2>/dev/null

# 确保 PPPoE 启用 IPv6CP
grep -q '+ipv6' /etc/ppp/options 2>/dev/null || echo '+ipv6' >> /etc/ppp/options

log "network: wan_6=dhcpv6c+PD(/56), lan=/64, ip6assign"

# ─────────────────────────────────────────────
# 3. IPv6 纯 SLAAC 模式 (最快获取速度)
# ─────────────────────────────────────────────
# DHCP 分工: dnsmasq(DHCPv4) + odhcpd(RA+RDNSS)
# maindhcp=0: 关键! 设1会导致dnsmasq关闭DHCPv4
# 因为init script检测到maindhcp=1时设置DNSMASQ_DHCP_VER=0
uci set dhcp.odhcpd.maindhcp='0'

# LAN: 纯 SLAAC (无 DHCPv6 开销, 最快 ~1s 获取地址)
# RDNSS 在 RA 中直接提供 DNS, 无需 DHCPv6
# dhcpv6=disabled → M=0 O=1, 客户端 SLAAC 获取地址
# ndp=disabled → 内核处理 NDP, 减少 odhcpd 处理延迟
# ra_mtu=1452 → PPPoE MTU 1492 - 40, 防大包丢包
uci set dhcp.lan.ra='server'
uci set dhcp.lan.dhcpv6='disabled'
uci set dhcp.lan.ndp='disabled'
uci set dhcp.lan.ra_management='0'
uci set dhcp.lan.ra_default='1'
uci set dhcp.lan.master='1'
uci set dhcp.lan.ra_mtu='1452'
uci set dhcp.lan.ra_mininterval='20'
uci set dhcp.lan.ra_maxinterval='60'

# 禁用路由器侧 DAD (无其他路由器在 LAN, 安全)
sysctl -w net.ipv6.conf.br-lan.dad_transmits=0 2>/dev/null
sysctl -w net.ipv6.conf.br-lan.accept_dad=0 2>/dev/null

log "dhcp: dnsmasq(DHCPv4) + odhcpd(SLAAC+RA), pure SLAAC, RA 20-60s"

# ─────────────────────────────────────────────
# 4. HTTPS DNS 代理 → AliDNS DoH (AAAA 支持)
# ─────────────────────────────────────────────
while uci delete https-dns-proxy.@https-dns-proxy[0] 2>/dev/null; do :; done

uci set https-dns-proxy.config=main
uci set https-dns-proxy.config.update_dnsmasq_config='*'
uci set https-dns-proxy.config.force_dns='1'
uci set https-dns-proxy.config.force_dns_port='53' '853'

uci add https-dns-proxy https-dns-proxy
uci set https-dns-proxy.@https-dns-proxy[-1].bootstrap_dns='223.5.5.5,223.6.6.6'
uci set https-dns-proxy.@https-dns-proxy[-1].resolver_url='https://dns.alidns.com/dns-query'
uci set https-dns-proxy.@https-dns-proxy[-1].listen_addr='127.0.0.1'
uci set https-dns-proxy.@https-dns-proxy[-1].listen_port='5054'
uci set https-dns-proxy.@https-dns-proxy[-1].user='nobody'
uci set https-dns-proxy.@https-dns-proxy[-1].group='nogroup'

log "https-dns-proxy: AliDNS DoH (127.0.0.1:5054, A+AAAA)"

# ─────────────────────────────────────────────
# 5. DNSMasq → 全部走 AliDNS DoH
# ─────────────────────────────────────────────
while uci delete dhcp.@dnsmasq[0].server 2>/dev/null; do :; done

uci add_list dhcp.@dnsmasq[0].server='127.0.0.1#5054'
uci set dhcp.@dnsmasq[0].noresolv='1'
uci set dhcp.@dnsmasq[0].cachesize='8192'
uci set dhcp.@dnsmasq[0].ednspacket_max='1232'

log "dnsmasq: server=127.0.0.1#5054"

# ─────────────────────────────────────────────
# 6. 提交全部 UCI 配置
# ─────────────────────────────────────────────
uci commit firewall
uci commit network
uci commit dhcp
uci commit https-dns-proxy

log "All UCI configs committed. Done."
