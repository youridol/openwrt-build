#!/bin/sh
# shellcheck shell=dash
# Restore persistent rules after LAN interface comes up

. /usr/local/bin/trafficctl-fw.sh

# Clean up nft monitor table on lan ifdown to avoid stale counters
if [ "$ACTION" = "ifdown" ] && [ "$INTERFACE" = "lan" ]; then
    nft delete table inet trafficctl_mon 2>/dev/null
    exit 0
fi

[ "$ACTION" = "ifup" ] && [ "$INTERFACE" = "lan" ] || exit 0

SHAPES_FILE="/etc/trafficctl/shapes.json"
RULES_FILE="/etc/trafficctl/rules.json"

# Wait for network stack to be ready (up to 10 seconds)
tries=0
while ! tc qdisc show dev "$(tctl_get_lan_device)" >/dev/null 2>&1; do
    tries=$((tries + 1))
    [ "$tries" -ge 20 ] && break
    sleep 0.5 2>/dev/null || sleep 1
done

# Restore shaping rules
if [ -f "$SHAPES_FILE" ]; then
    jsonfilter -i "$SHAPES_FILE" -e '@[*].ip' 2>/dev/null | while read -r ip; do
        rate=$(jsonfilter -i "$SHAPES_FILE" -e "@[@.ip='$ip'].rate_kbit" 2>/dev/null)
        if [ -n "$rate" ] && [ "$rate" != "0" ]; then
            /usr/local/bin/trafficctl-shape.sh add "$ip" "$rate" || \
                logger -t trafficctl "Failed to restore shape for $ip (${rate}kbit)"
        fi
    done
fi

# Restore blocks and ratelimits (if persist enabled)
if [ -f "$RULES_FILE" ] && tctl_persist_enabled; then
    jsonfilter -i "$RULES_FILE" -e '@[*]' 2>/dev/null | while read -r _; do true; done

    for idx in $(seq 0 99); do
        type=$(jsonfilter -i "$RULES_FILE" -e "@[$idx].type" 2>/dev/null)
        [ -z "$type" ] && break
        ip=$(jsonfilter -i "$RULES_FILE" -e "@[$idx].ip" 2>/dev/null)
        param=$(jsonfilter -i "$RULES_FILE" -e "@[$idx].param" 2>/dev/null)
        [ -z "$ip" ] && continue

        case "$type" in
            block)
                tctl_block_add "$ip" "tctl_block_${param}" 2>/dev/null || \
                    logger -t trafficctl "Failed to restore block for $ip"
                ;;
            ratelimit)
                [ -n "$param" ] && [ "$param" != "0" ] && \
                    tctl_ratelimit_add "$ip" "$param" "rl_ratelimit_${ip}" 2>/dev/null || \
                    logger -t trafficctl "Failed to restore ratelimit for $ip (${param}kbit)"
                ;;
        esac
    done
fi

# Pre-create nft monitor table if software offload is active
if [ "$(tctl_get_offload_mode)" = "software" ]; then
    /usr/local/bin/trafficctl-bytes-nft.sh >/dev/null 2>&1 &
fi
