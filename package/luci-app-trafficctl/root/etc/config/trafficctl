config trafficctl 'main'
	option enabled '1'
	option default_mode 'limiter'
	option persist_rules '0'

config logging 'logging'
	option enabled '1'
	option log_file '/tmp/trafficctl/activity.log'
	option max_lines '500'
	option syslog '1'
	option log_blocks '1'
	option log_ratelimits '1'
	option log_shapes '1'
	option log_telegram '1'
	option log_config '1'

config telegram 'telegram'
	option enabled '0'
	option bot_token ''
	option chat_id ''
	option poll_interval '3'
	option notify_new_device '1'
	option notify_known_device '0'
	option control_enabled '1'
	option notify_template ''
	option btn_block_inet '1'
	option btn_block_wifi '1'
	option btn_limiter '1'
	option btn_shaper '1'
