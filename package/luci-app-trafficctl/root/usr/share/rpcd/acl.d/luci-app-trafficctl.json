{
	"luci-app-trafficctl": {
		"description": "Grant access to LuCI Traffic Control",
		"read": {
			"ubus": {
				"luci.trafficctl": [
					"version",
					"summary", "device", "bytes",
					"ratelimit_stats", "shape_stats", "rdns",
					"config_get", "telegram_config_get",
					"logging_config_get", "activity_log"
				],
				"file": [ "read" ]
			},
			"uci": [ "trafficctl", "wireless", "network" ],
			"file": {
				"/tmp/dhcp.leases": [ "read" ]
			}
		},
		"write": {
			"ubus": {
				"luci.trafficctl": [
					"block", "unblock",
					"macfilter_add", "macfilter_remove",
					"ratelimit", "shape_add", "shape_remove", "shape_status",
					"config_set",
					"telegram_config_set", "telegram_test",
					"logging_config_set",
					"config_set"
				]
			},
			"uci": [ "trafficctl" ]
		}
	}
}
